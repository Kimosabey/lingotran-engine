# =============================================================================
# German Web Extractor — environment template
# Copy to `.env` and adjust. NO website-specific values belong here; per-site
# behaviour is declared in an adapter (see adapters/README.md), not in config.
# =============================================================================

# --- Crawl politeness --------------------------------------------------------
WEB_EXTRACTOR_USER_AGENT="LingotranBot/0.1 (+authorized-crawl; contact: you@example.com)"
RESPECT_ROBOTS=true              # never set false without written authorization
REQUEST_DELAY_MS=1500            # min delay between requests to the same host
MAX_CONCURRENCY=2                # simultaneous in-flight pages (per host)
NAV_TIMEOUT_MS=30000             # Playwright navigation timeout
MAX_RETRIES=3                    # transient-failure retry attempts
RETRY_BACKOFF_MS=1000            # base backoff (exponential)

# --- Output ------------------------------------------------------------------
# Corpus output root — stays inside the German language folder.
OUTPUT_DIR="../extracted"        # resolved relative to this module
EMIT_JSON=true
EMIT_MARKDOWN=true

# --- Logging -----------------------------------------------------------------
LOG_LEVEL=info                   # trace | debug | info | warn | error
LOG_PRETTY=true

# --- Optional cloud enrichment (disabled by default; extraction is the core) -
# The deterministic pipeline runs fully without these. Enrichment is a
# pluggable pipeline stage, not a requirement.
ENRICHMENT_ENABLED=false
# ANTHROPIC_API_KEY=
# ENRICHMENT_MODEL=claude-opus-4-8
