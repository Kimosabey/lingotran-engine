{
  "name": "@lingotran/german-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Lingotran German corpus — web source-acquisition module. Adapter-driven, framework-agnostic content extraction foundation. Extraction only (no UI).",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.json",
