{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["node"],

    "strict": true,
    "noUncheckedIndexedAccess": true,
    // Relaxed intentionally: zod's `.optional()` yields `T | undefined`, which
    // clashes with `field?: T` under exactOptionalPropertyTypes across the
    // model<->schema boundary. Off keeps that interop friction-free.
    "exactOptionalPropertyTypes": false,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,
    "verbatimModuleSyntax": true,

    "declaration": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": ".",

    "skipLibCheck": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "isolatedModules": true
  },
  "include": [
    "adapters/**/*.ts",
    "extractors/**/*.ts",
    "parsers/**/*.ts",
    "transformers/**/*.ts",
    "validators/**/*.ts",
    "pipelines/**/*.ts",
    "schemas/**/*.ts",
    "config/**/*.ts",
    "models/**/*.ts",
    "utils/**/*.ts",
    "tests/**/*.ts",
    "cli.ts"
  ],
  "exclude": ["dist", "node_modules"]
}
