    {
      "id": "n20",
      "type": "heading",
      "order": 19,
      "level": 2,
      "text": "What the TELC B1 Exam Checks"
    },
    {
      "id": "n21",
      "type": "paragraph",
      "order": 20,
      "text": "Zertifikat Deutsch / telc Deutsch B1 tests everyday German for personal and professional communication at CEFR B1."
    },
    {
      "id": "n22",
      "type": "heading",
      "order": 21,
      "level": 3,
      "text": "Exam format and timing"
    },
    {
      "id": "n23",
      "type": "paragraph",
      "order": 22,
      "text": "The telc B1 qualification consists of a written examination and an oral examination."
    },
    {
      "id": "n24",
      "type": "heading",
      "order": 23,
      "level": 4,
      "text": "Reading and language elements"
    },
    {
      "id": "n25",
      "type": "paragraph",
      "order": 24,
      "text": "90 minutes"
    },
    {
      "id": "n26",
      "type": "paragraph",
      "order": 25,
      "text": "Reading has three parts and language elements has two parts, with no break."
    },
    {
      "id": "n27",
      "type": "heading",
      "order": 26,
      "level": 4,
      "text": "Listening"
    },
    {
      "id": "n28",
      "type": "paragraph",
      "order": 27,
      "text": "Approx. 30 minutes"
    },
    {
      "id": "n29",
      "type": "paragraph",
      "order": 28,
      "text": "Three listening parts in the written examination."
    },
    {
      "id": "n30",
      "type": "heading",
      "order": 29,
      "level": 4,
      "text": "Writing"
    },
    {
      "id": "n31",
      "type": "paragraph",
      "order": 30,
      "text": "30 minutes"
    },
    {
      "id": "n32",
      "type": "paragraph",
      "order": 31,
      "text": "One writing task in the written examination."
    },
    {
      "id": "n33",
      "type": "heading",
      "order": 32,
      "level": 4,
      "text": "Speaking"
    },
    {
      "id": "n34",
      "type": "paragraph",
      "order": 33,
      "text": "Approx. 15 minutes"
    },
    {
      "id": "n35",
      "type": "paragraph",
      "order": 34,
      "text": "Three speaking parts, pair examination, with 20 minutes of preparation time."
    },
    {
      "id": "n36",
      "type": "heading",
      "order": 35,
      "level": 3,
      "text": "Best for"
    },
    {
      "id": "n37",
      "type": "heading",
      "order": 36,
      "level": 4,
      "text": "Independent everyday German"
    },
    {
      "id": "n38",
      "type": "paragraph",
      "order": 37,
      "text": "Useful for personal and professional situations, including receptive and productive tasks."
    },
    {
      "id": "n39",
      "type": "heading",
      "order": 38,
      "level": 4,
      "text": "Residence and citizenship preparation"
    },
    {
      "id": "n40",
      "type": "paragraph",
      "order": 39,
      "text": "Relevant when an authority asks for B1 German. Confirm the accepted certificate version before booking."
    },
    {
      "id": "n41",
      "type": "heading",
      "order": 40,
      "level": 3,
      "text": "How to use your practice time"
    },
    {
      "id": "n42",
      "type": "list",
      "order": 41,
      "ordered": false,
      "items": [
        {
          "text": "Receptive skills plus productive writing and speaking responses."
        },
        {
          "text": "Personal and professional topic vocabulary."
        },
        {
          "text": "Writing feedback for task completion, organization, and language accuracy."
        }
      ]
    },
    {
      "id": "n43",
      "type": "heading",
      "order": 42,
      "level": 2,
      "text": "Frequently Asked Questions"
    },
    {
      "id": "n44",
      "type": "paragraph",
      "order": 43,
      "text": "Everything you need to know about the exam!"
    },
    {
      "id": "n45",
      "type": "paragraph",
      "order": 44,
      "text": "B1 is commonly requested for independent German skills in naturalization contexts. Check with the authority processing your application."
    },
    {
      "id": "n46",
      "type": "paragraph",
      "order": 45,
      "text": "Reading, language elements, listening, writing, and an oral pair exam with preparation time."
    },
    {
      "id": "n47",
      "type": "paragraph",
      "order": 46,
      "text": "Balance reading/listening accuracy with clear writing, examples in speaking, and everyday personal or work-related topics."
    },
    {
      "id": "n48",
      "type": "paragraph",
      "order": 47,
      "text": "Last reviewed: May 2026. This page is independent exam preparation. For official registration, fees, dates, and accepted certificate rules, check the exam provider and the institution or authority requesting your certificate."
    }
