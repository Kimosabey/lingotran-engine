  "nodes": [
    {
      "id": "n1",
      "type": "heading",
      "order": 0,
      "level": 3,
      "text": "About the Section"
    },
    {
      "id": "n2",
      "type": "image",
      "order": 1,
      "src": "https://deutsch-pruefung.de/_next/image?url=%2Fsection-assets%2Fbear-mascot.webp&w=384&q=75",
      "alt": "Study bear mascot"
    },
    {
      "id": "n3",
      "type": "paragraph",
      "order": 2,
      "text": "The TELC B2 Mündlicher Ausdruck (Speaking) module takes approximately 15 minutes with a 20-minute preparation phase (Vorbereitungszeit). The exam is conducted in pairs and consists of three parts testing your ability to speak about experiences, discuss topics, and plan activities together."
    },
    {
      "id": "n4",
      "type": "heading",
      "order": 3,
      "level": 4,
      "text": "Teil 1: Über Erfahrungen sprechen (Talking About Experiences)"
    },
    {
      "id": "n5",
      "type": "paragraph",
      "order": 4,
      "text": "• Choose one topic from 7 options (book, film, trip, music event, sports event, important person, important experience)"
    },
    {
      "id": "n6",
      "type": "paragraph",
      "order": 5,
      "text": "• Speak for about 1½ minutes about your chosen topic"
    },
    {
      "id": "n7",
      "type": "heading",
      "order": 6,
      "level": 4,
      "text": "Teil 2: Diskussion (Discussion)"
    },
    {
      "id": "n8",
      "type": "paragraph",
      "order": 7,
      "text": "• Discuss a controversial topic with your partner"
    },
    {
      "id": "n9",
      "type": "paragraph",
      "order": 8,
      "text": "• State your opinion and defend it with arguments"
    },
    {
      "id": "n10",
      "type": "heading",
      "order": 9,
      "level": 4,
      "text": "Teil 3: Gemeinsam etwas planen (Planning Together)"
    },
    {
      "id": "n11",
      "type": "paragraph",
      "order": 10,
      "text": "• Plan an activity or event together with your partner"
    },
    {
      "id": "n12",
      "type": "paragraph",
      "order": 11,
      "text": "• Make suggestions and respond to your partner's ideas"
    },
    {
      "id": "n13",
      "type": "heading",
      "order": 12,
      "level": 3,
      "text": "Teil 1 - Über Erfahrungen sprechen (Talking About Experiences)"
