    {
      "id": "n3",
      "type": "paragraph",
      "order": 2,
      "text": "The Goethe A2 Reading module takes 30 minutes and tests your ability to understand everyday written texts. You will read various texts from daily life and complete four different tasks."
    },
    {
      "id": "n4",
      "type": "heading",
      "order": 3,
      "level": 4,
      "text": "Teil 1: Understanding Media Texts"
    },
    {
      "id": "n5",
      "type": "paragraph",
      "order": 4,
      "text": "• Read short texts from newspapers, magazines, or online sources"
    },
    {
      "id": "n6",
      "type": "paragraph",
      "order": 5,
      "text": "• Understand information and simple arguments in everyday media"
    },
    {
      "id": "n7",
      "type": "heading",
      "order": 6,
      "level": 4,
      "text": "Teil 2: Information Boards & Event Programs"
    },
    {
      "id": "n8",
      "type": "paragraph",
      "order": 7,
      "text": "• Read information boards, event schedules, or public notices"
    },
    {
      "id": "n9",
      "type": "paragraph",
      "order": 8,
      "text": "• Find specific information quickly and understand practical details"
    },
    {
      "id": "n10",
      "type": "heading",
      "order": 9,
      "level": 4,
      "text": "Teil 3: Understanding Correspondence"
    },
    {
      "id": "n11",
      "type": "paragraph",
      "order": 10,
      "text": "• Read personal or semi-formal emails and letters"
    },
    {
      "id": "n12",
      "type": "paragraph",
      "order": 11,
      "text": "• Understand the writer's intention and key information"
    },
    {
      "id": "n13",
      "type": "heading",
      "order": 12,
      "level": 4,
      "text": "Teil 4: Understanding Advertisements"
    },
    {
      "id": "n14",
      "type": "paragraph",
      "order": 13,
      "text": "• Read various advertisements and announcements"
    },
    {
      "id": "n15",
      "type": "paragraph",
      "order": 14,
      "text": "• Match situations or needs to the appropriate advertisement"
    },
    {
