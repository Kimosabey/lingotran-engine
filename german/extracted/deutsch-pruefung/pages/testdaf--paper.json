    },
    {
      "id": "n23",
      "type": "heading",
      "order": 21,
      "level": 2,
      "text": "Mündlicher Ausdruck"
    },
    {
      "id": "n25",
      "type": "paragraph",
      "order": 22,
      "text": "7 computer-recorded tasks"
    },
    {
      "id": "n26",
      "type": "paragraph",
      "order": 23,
      "text": "35 minutes"
    },
    {
      "id": "n27",
      "type": "heading",
      "order": 24,
      "level": 2,
      "text": "Official Paper-Based TestDaF Order"
    },
    {
      "id": "n28",
      "type": "paragraph",
      "order": 25,
      "text": "The official paper-based sequence is fixed: reading first, then listening, then handwritten writing, then computer-recorded speaking. This makes preparation easier because your practice plan can follow the same rhythm every time."
    },
    {
      "id": "n30",
      "type": "paragraph",
      "order": 26,
      "text": "3 reading texts, 30 items · 60 minutes"
    },
    {
      "id": "n31",
      "type": "list",
      "order": 27,
      "ordered": false,
      "items": [
        {
          "text": "Text 1: short texts with 10 matching items."
        },
        {
          "text": "Text 2: journalistic text with 10 multiple-choice items."
        },
        {
          "text": "Text 3: specialist-journal style text with 10 Ja / Nein / Text sagt dazu nichts items."
        }
      ]
    },
    {
      "id": "n33",
      "type": "paragraph",
      "order": 28,
      "text": "3 audio texts, 25 items · 40 minutes"
    },
    {
      "id": "n34",
      "type": "list",
      "order": 29,
      "ordered": false,
      "items": [
        {
          "text": "Text 1: dialogue with 8 short answers."
        },
        {
          "text": "Text 2: interview with 10 richtig/falsch items."
        },
        {
          "text": "Text 3: lecture or interview with 7 short answers."
        }
      ]
    },
    {
      "id": "n36",
      "type": "paragraph",
      "order": 30,
      "text": "1 handwritten task · 60 minutes"
    },
    {
      "id": "n37",
      "type": "list",
      "order": 31,
      "ordered": false,
      "items": [
        {
          "text": "Write one structured text."
        },
        {
          "text": "Include a graph or chart description."
        },
        {
          "text": "Develop an argumentation section connected to the task."
        }
      ]
    },
    {
      "id": "n39",
      "type": "paragraph",
      "order": 32,
      "text": "7 computer-recorded tasks · 35 minutes"
    },
    {
      "id": "n40",
      "type": "list",
      "order": 33,
      "ordered": false,
      "items": [
        {
          "text": "Speak in typical university situations."
        },
        {
          "text": "Hear tasks through headphones and answer into a microphone."
        },
        {
          "text": "There is no live examiner conversation in the paper-based TestDaF speaking part."
        }
      ]
    },
    {
      "id": "n41",
      "type": "heading",
      "order": 34,
      "level": 2,
      "text": "Scoring Facts"
    },
    {
      "id": "n42",
      "type": "paragraph",
      "order": 35,
      "text": "The four parts are evaluated separately. Reading and listening answer sheets are scanned; short listening answers are checked by trained raters. Writing and speaking are assessed by trained TestDaF raters using official criteria."
    },
    {
      "id": "n43",
      "type": "paragraph",
      "order": 36,
      "text": "The exact minimum can shift by test set because TestDaF adjusts raw-score thresholds statistically for reading and listening."
    },
    {
      "id": "n44",
      "type": "heading",
      "order": 37,
      "level": 2,
      "text": "Tips Based on Official Criteria"
    },
    {
      "id": "n46",
      "type": "list",
      "order": 38,
      "ordered": false,
      "items": [
        {
          "text": "Use the fixed task order to your advantage: matching first, then multiple choice, then statement checking."
        },
        {
          "text": "Separate what the text actually says from what sounds plausible. This matters especially for Text sagt dazu nichts."
        },
        {
          "text": "Leave enough time to transfer answers cleanly because only the answer sheet is assessed."
        }
      ]
    },
    {
      "id": "n48",
      "type": "list",
      "order": 39,
      "ordered": false,
      "items": [
        {
          "text": "Expect Texts 1 and 2 once, and Text 3 twice; plan your notes around that official listening rhythm."
        },
        {
          "text": "For short answers, write compact information while listening, then transfer carefully at the end."
        },
        {
          "text": "Listen for the speaker purpose, key reasons, examples, and main claims, not isolated vocabulary only."
        }
      ]
    },
    {
      "id": "n50",
      "type": "list",
      "order": 40,
      "ordered": false,
      "items": [
        {
          "text": "Build a visible structure: introduction, graph description, transition, argumentation, and conclusion."
        },
        {
          "text": "Describe the important graph information accurately before evaluating or arguing."
        },
        {
          "text": "Use varied connectors and sentence structures because official assessment considers coherence, vocabulary, syntax, and comprehensibility."
        }
      ]
    },
    {
      "id": "n52",
      "type": "list",
      "order": 41,
      "ordered": false,
      "items": [
        {
          "text": "Read the situation closely: your role, partner, topic, formality, and exact action decide the answer."
        },
        {
          "text": "Use preparation time to create a tiny structure, not a full script."
        },
        {
          "text": "Aim for clear, fluent, task-focused speech because official assessment considers overall effect, task fulfilment, and language resources."
        }
      ]
    },
    {
      "id": "n53",
      "type": "heading",
      "order": 42,
      "level": 2,
      "text": "Test-Day Rules to Remember"
    },
    {
      "id": "n54",
      "type": "heading",
      "order": 43,
      "level": 2,
      "text": "Continue Practicing"
    },
    {
      "id": "n55",
      "type": "heading",
      "order": 44,
      "level": 2,
      "text": "Official Sources Used"
    },
    {
      "id": "n56",
      "type": "paragraph",
      "order": 45,
      "text": "This guide is based on official TestDaF information for the paper-based exam structure, evaluation, and examination procedure."
    }
