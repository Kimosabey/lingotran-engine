    {
      "id": "n3",
      "type": "paragraph",
      "order": 2,
      "text": "The official telc Deutsch A2 Hören subtest lasts about 20 minutes, has 15 items, and consists of three Teile. In the model test, you complete telephone notes, answer radio-information multiple-choice tasks, and match details from one longer conversation."
    },
    {
      "id": "n4",
      "type": "heading",
      "order": 3,
      "level": 4,
      "text": "Teil 1: Ansagen am Telefon (Telephone Messages)"
    },
    {
      "id": "n5",
      "type": "paragraph",
      "order": 4,
      "text": "• You hear five telephone messages"
    },
    {
      "id": "n6",
      "type": "paragraph",
      "order": 5,
      "text": "• Complete five telephone notes with the missing information"
    },
    {
      "id": "n7",
      "type": "heading",
      "order": 6,
      "level": 4,
      "text": "Teil 2: Informationen aus dem Radio (Radio Information)"
    },
    {
      "id": "n8",
      "type": "paragraph",
      "order": 7,
      "text": "• You hear five short radio texts"
    },
    {
      "id": "n9",
      "type": "paragraph",
      "order": 8,
      "text": "• Choose the correct answer: a, b, or c"
    },
    {
      "id": "n10",
      "type": "heading",
      "order": 9,
      "level": 4,
      "text": "Teil 3: Ein Gespräch (Conversation)"
    },
    {
      "id": "n11",
      "type": "paragraph",
      "order": 10,
      "text": "• You hear one longer conversation"
    },
    {
      "id": "n12",
      "type": "paragraph",
      "order": 11,
      "text": "• Match the people or items to the correct option and write the letter"
    },
    {
