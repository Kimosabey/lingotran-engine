    },
    {
      "id": "n19",
      "type": "paragraph",
      "order": 18,
      "text": "Official exam context"
    },
    {
      "id": "n20",
      "type": "heading",
      "order": 19,
      "level": 2,
      "text": "What the TELC B2 Exam Checks"
    },
    {
      "id": "n21",
      "type": "paragraph",
      "order": 20,
      "text": "telc Deutsch B2 demonstrates upper-intermediate German in reading, listening, writing, speaking, and everyday communication."
    },
    {
      "id": "n22",
      "type": "heading",
      "order": 21,
      "level": 3,
      "text": "Exam format and timing"
    },
    {
      "id": "n23",
      "type": "paragraph",
      "order": 22,
      "text": "The telc B2 exam consists of a written and an oral examination and is available in digital, hybrid, and paper-based formats."
    },
    {
      "id": "n24",
      "type": "heading",
      "order": 23,
      "level": 4,
      "text": "Reading and language elements"
    },
    {
      "id": "n25",
      "type": "paragraph",
      "order": 24,
      "text": "90 minutes"
    },
    {
      "id": "n26",
      "type": "paragraph",
      "order": 25,
      "text": "Reading has three parts and language elements has two parts, with no break."
    },
    {
      "id": "n27",
      "type": "heading",
      "order": 26,
      "level": 4,
      "text": "Listening"
    },
    {
      "id": "n28",
      "type": "paragraph",
      "order": 27,
      "text": "Approx. 20 minutes"
    },
    {
      "id": "n29",
      "type": "paragraph",
      "order": 28,
      "text": "Three listening parts in the written examination."
    },
    {
      "id": "n30",
      "type": "heading",
      "order": 29,
      "level": 4,
      "text": "Writing"
    },
    {
      "id": "n31",
      "type": "paragraph",
      "order": 30,
      "text": "30 minutes"
    },
    {
      "id": "n32",
      "type": "paragraph",
      "order": 31,
      "text": "One writing task in the written examination."
    },
    {
      "id": "n33",
      "type": "heading",
      "order": 32,
      "level": 4,
      "text": "Speaking"
    },
    {
      "id": "n34",
      "type": "paragraph",
      "order": 33,
      "text": "Approx. 15 minutes"
    },
    {
      "id": "n35",
      "type": "paragraph",
      "order": 34,
      "text": "Three speaking parts, pair examination, with 20 minutes of preparation time."
    },
    {
      "id": "n36",
      "type": "heading",
      "order": 35,
      "level": 3,
      "text": "Best for"
    },
    {
      "id": "n37",
      "type": "heading",
      "order": 36,
      "level": 4,
      "text": "Advanced work and study preparation"
    },
    {
      "id": "n38",
      "type": "paragraph",
      "order": 37,
      "text": "Useful for more independent workplace language, complex input, and upper-intermediate communication."
    },
    {
      "id": "n39",
      "type": "heading",
      "order": 38,
      "level": 4,
      "text": "University route research"
    },
    {
      "id": "n40",
      "type": "paragraph",
      "order": 39,
      "text": "Some routes may accept B2, but many German-taught programs require C1-level or university-specific proof."
    },
    {
      "id": "n41",
      "type": "heading",
      "order": 40,
      "level": 3,
      "text": "How to use your practice time"
    },
    {
      "id": "n42",
      "type": "list",
      "order": 41,
      "ordered": false,
      "items": [
        {
          "text": "Reading and listening tasks that require main ideas and specific details."
        },
        {
          "text": "Structured writing responses to given input."
        },
        {
          "text": "Paired speaking with examples, reasons, counterpoints, and follow-up answers."
        }
      ]
    },
    {
      "id": "n43",
      "type": "heading",
      "order": 42,
      "level": 2,
      "text": "Frequently Asked Questions"
    },
    {
      "id": "n44",
      "type": "paragraph",
      "order": 43,
      "text": "Everything you need to know about the exam!"
    },
    {
      "id": "n45",
      "type": "paragraph",
      "order": 44,
      "text": "Some routes may accept B2, but many German-taught programs require C1-level or specific proofs such as telc Deutsch C1 Hochschule, DSH, or TestDaF."
    },
    {
      "id": "n46",
      "type": "paragraph",
      "order": 45,
      "text": "TELC describes B2 speaking as three parts, normally a pair examination, with 20 minutes of preparation time."
    },
    {
      "id": "n47",
      "type": "paragraph",
      "order": 46,
      "text": "Practise responding directly to the task, organizing arguments clearly, using connectors, and checking grammar under time pressure."
    },
    {
      "id": "n48",
      "type": "paragraph",
      "order": 47,
      "text": "Last reviewed: May 2026. This page is independent exam preparation. For official registration, fees, dates, and accepted certificate rules, check the exam provider and the institution or authority requesting your certificate."
    }
