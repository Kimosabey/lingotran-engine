      "level": 3,
      "text": "About the Section"
    },
    {
      "id": "n2",
      "type": "image",
      "order": 1,
      "src": "https://deutsch-pruefung.de/_next/image?url=%2Fsection-assets%2Fbear-mascot.webp&w=384&q=75",
      "alt": "Study bear mascot"
    },
    {
      "id": "n3",
      "type": "paragraph",
      "order": 2,
      "text": "The TELC B1 Leseverstehen (Reading) module takes 90 minutes and consists of three reading parts plus Sprachbausteine (Language Elements)."
    },
    {
      "id": "n4",
      "type": "heading",
      "order": 3,
      "level": 4,
      "text": "Teil 1: Globalverstehen (Global Reading)"
    },
    {
      "id": "n5",
      "type": "paragraph",
      "order": 4,
      "text": "• Read workplace-related texts (emails, notices, short articles)"
    },
    {
      "id": "n6",
      "type": "paragraph",
      "order": 5,
      "text": "• Match texts to situations or understand main ideas"
    },
    {
      "id": "n7",
      "type": "heading",
      "order": 6,
      "level": 4,
      "text": "Teil 2: Detailverstehen (Detailed Reading)"
    },
    {
      "id": "n8",
      "type": "paragraph",
      "order": 7,
      "text": "• Read longer professional texts carefully"
    },
    {
      "id": "n9",
      "type": "paragraph",
      "order": 8,
      "text": "• Answer detailed questions about specific information"
    },
    {
      "id": "n10",
      "type": "heading",
      "order": 9,
      "level": 4,
      "text": "Teil 3: Selektives Verstehen (Selective Reading)"
    },
    {
      "id": "n11",
      "type": "paragraph",
      "order": 10,
      "text": "• Scan texts quickly for specific information"
    },
    {
      "id": "n12",
      "type": "paragraph",
      "order": 11,
      "text": "• Match situations, needs, or questions to text segments"
    },
    {
      "id": "n13",
      "type": "heading",
      "order": 12,
      "level": 4,
      "text": "Teil 4: Sprachbausteine Teil 1 (Language Elements Part 1)"
    },
    {
      "id": "n14",
      "type": "paragraph",
      "order": 13,
      "text": "• Complete gaps in a text using grammar and vocabulary knowledge"
    },
    {
      "id": "n15",
      "type": "paragraph",
      "order": 14,
      "text": "• Choose the correct word/phrase from multiple options"
    },
    {
      "id": "n16",
      "type": "heading",
      "order": 15,
      "level": 4,
      "text": "Teil 5: Sprachbausteine Teil 2 (Language Elements Part 2)"
    },
    {
      "id": "n17",
      "type": "paragraph",
      "order": 16,
      "text": "• Match words or phrases to complete a coherent text"
    },
    {
      "id": "n18",
      "type": "paragraph",
      "order": 17,
      "text": "• Test understanding of sentence structure and context"
    },
    {
      "id": "n19",
      "type": "heading",
      "order": 18,
      "level": 3,
      "text": "Teil 1 - Globalverstehen (Global Reading)"
