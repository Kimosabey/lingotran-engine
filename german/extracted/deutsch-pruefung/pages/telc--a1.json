    {
      "id": "n20",
      "type": "heading",
      "order": 19,
      "level": 2,
      "text": "What the TELC A1 Exam Checks"
    },
    {
      "id": "n21",
      "type": "paragraph",
      "order": 20,
      "text": "Start Deutsch 1 / telc Deutsch A1 demonstrates beginner German skills at CEFR A1 for simple everyday communication."
    },
    {
      "id": "n22",
      "type": "heading",
      "order": 21,
      "level": 3,
      "text": "Exam format and timing"
    },
    {
      "id": "n23",
      "type": "paragraph",
      "order": 22,
      "text": "The exam consists of a written part and an oral part. It cannot be taken as a partial examination."
    },
    {
      "id": "n24",
      "type": "heading",
      "order": 23,
      "level": 4,
      "text": "Listening"
    },
    {
      "id": "n25",
      "type": "paragraph",
      "order": 24,
      "text": "Approx. 20 minutes"
    },
    {
      "id": "n26",
      "type": "paragraph",
      "order": 25,
      "text": "Three parts in the written examination."
    },
    {
      "id": "n27",
      "type": "heading",
      "order": 26,
      "level": 4,
      "text": "Reading and writing"
    },
    {
      "id": "n28",
      "type": "paragraph",
      "order": 27,
      "text": "45 minutes"
    },
    {
      "id": "n29",
      "type": "paragraph",
      "order": 28,
      "text": "Reading has three parts and writing has two parts in the written examination."
    },
    {
      "id": "n30",
      "type": "heading",
      "order": 29,
      "level": 4,
      "text": "Speaking"
    },
    {
      "id": "n31",
      "type": "paragraph",
      "order": 30,
      "text": "Approx. 15 minutes"
    },
    {
      "id": "n32",
      "type": "paragraph",
      "order": 31,
      "text": "Three parts, usually with four test takers and no preparation time."
    },
    {
      "id": "n33",
      "type": "heading",
      "order": 32,
      "level": 3,
      "text": "Best for"
    },
    {
      "id": "n34",
      "type": "heading",
      "order": 33,
      "level": 4,
      "text": "Beginner German proof"
    },
    {
      "id": "n35",
      "type": "paragraph",
      "order": 34,
      "text": "Useful for simple everyday communication and contexts where an A1 certificate is requested."
    },
    {
      "id": "n36",
      "type": "heading",
      "order": 35,
      "level": 4,
      "text": "Visa or authority preparation"
    },
    {
      "id": "n37",
      "type": "paragraph",
      "order": 36,
      "text": "TELC certificates can be relevant for official routes, but the accepted certificate name must match the authority request."
    },
    {
      "id": "n38",
      "type": "heading",
      "order": 37,
      "level": 3,
      "text": "How to use your practice time"
    },
    {
      "id": "n39",
      "type": "list",
      "order": 38,
      "ordered": false,
      "items": [
        {
          "text": "Simple everyday tasks with multiple-choice, matching, short writing, and spoken prompts."
        },
        {
          "text": "Short, clear answers for personal information and everyday needs."
        },
        {
          "text": "Listening drills for common public and everyday situations."
        }
      ]
    },
    {
      "id": "n40",
      "type": "heading",
      "order": 39,
      "level": 2,
      "text": "Frequently Asked Questions"
    },
    {
      "id": "n41",
      "type": "paragraph",
      "order": 40,
      "text": "Everything you need to know about the exam!"
    },
    {
      "id": "n42",
      "type": "paragraph",
      "order": 41,
      "text": "It demonstrates beginner German for simple everyday situations and may be relevant where an authority asks for A1 proof."
    },
    {
      "id": "n43",
      "type": "paragraph",
      "order": 42,
      "text": "TELC describes A1 speaking as usually having no preparation time, so quick simple responses matter."
    },
    {
      "id": "n44",
      "type": "paragraph",
      "order": 43,
      "text": "Short listening, reading and writing tasks, basic personal topics, simple prompts, and partner speaking."
    },
    {
      "id": "n45",
      "type": "paragraph",
      "order": 44,
      "text": "Last reviewed: May 2026. This page is independent exam preparation. For official registration, fees, dates, and accepted certificate rules, check the exam provider and the institution or authority requesting your certificate."
    }
