    {
      "id": "n3",
      "type": "paragraph",
      "order": 2,
      "text": "The Goethe A2 Listening module takes 30 minutes and tests your ability to understand spoken German in everyday situations. You will hear various audio texts and complete four different tasks."
    },
    {
      "id": "n4",
      "type": "heading",
      "order": 3,
      "level": 4,
      "text": "Teil 1: Radio, Answering Machine & Announcements"
    },
    {
      "id": "n5",
      "type": "paragraph",
      "order": 4,
      "text": "• Listen to information on the radio, answering machines, or public announcements"
    },
    {
      "id": "n6",
      "type": "paragraph",
      "order": 5,
      "text": "• Understand key details from everyday audio messages"
    },
    {
      "id": "n7",
      "type": "heading",
      "order": 6,
      "level": 4,
      "text": "Teil 2: Understanding Conversations"
    },
    {
      "id": "n8",
      "type": "paragraph",
      "order": 7,
      "text": "• Listen to a coherent conversation or dialogue"
    },
    {
      "id": "n9",
      "type": "paragraph",
      "order": 8,
      "text": "• Match statements or pictures to what you hear"
    },
    {
      "id": "n10",
      "type": "heading",
      "order": 9,
      "level": 4,
      "text": "Teil 3: Individual Conversations"
    },
    {
      "id": "n11",
      "type": "paragraph",
      "order": 10,
      "text": "• Listen to short individual conversations"
    },
    {
      "id": "n12",
      "type": "paragraph",
      "order": 11,
      "text": "• Answer questions about specific details"
    },
    {
      "id": "n13",
      "type": "heading",
      "order": 12,
      "level": 4,
      "text": "Teil 4: Radio Interview"
    },
    {
      "id": "n14",
      "type": "paragraph",
      "order": 13,
      "text": "• Listen to a radio interview or discussion"
    },
    {
      "id": "n15",
      "type": "paragraph",
      "order": 14,
      "text": "• Decide if statements are Richtig (true) or Falsch (false)"
    },
