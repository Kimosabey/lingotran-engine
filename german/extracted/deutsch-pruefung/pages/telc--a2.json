    },
    {
      "id": "n19",
      "type": "paragraph",
      "order": 18,
      "text": "Official exam context"
    },
    {
      "id": "n20",
      "type": "heading",
      "order": 19,
      "level": 2,
      "text": "What the TELC A2 Exam Checks"
    },
    {
      "id": "n21",
      "type": "paragraph",
      "order": 20,
      "text": "Start Deutsch 2 / telc Deutsch A2 demonstrates German reading, listening, writing, and speaking skills at CEFR A2."
    },
    {
      "id": "n22",
      "type": "heading",
      "order": 21,
      "level": 3,
      "text": "Exam format and timing"
    },
    {
      "id": "n23",
      "type": "paragraph",
      "order": 22,
      "text": "The exam consists of a written part and an oral part. It cannot be taken as a partial examination."
    },
    {
      "id": "n24",
      "type": "heading",
      "order": 23,
      "level": 4,
      "text": "Listening"
    },
    {
      "id": "n25",
      "type": "paragraph",
      "order": 24,
      "text": "Approx. 20 minutes"
    },
    {
      "id": "n26",
      "type": "paragraph",
      "order": 25,
      "text": "Three parts in the written examination."
    },
    {
      "id": "n27",
      "type": "heading",
      "order": 26,
      "level": 4,
      "text": "Reading and writing"
    },
    {
      "id": "n28",
      "type": "paragraph",
      "order": 27,
      "text": "50 minutes"
    },
    {
      "id": "n29",
      "type": "paragraph",
      "order": 28,
      "text": "Reading has three parts and writing has two parts in the written examination."
    },
    {
      "id": "n30",
      "type": "heading",
      "order": 29,
      "level": 4,
      "text": "Speaking"
    },
    {
      "id": "n31",
      "type": "paragraph",
      "order": 30,
      "text": "Approx. 15 minutes"
    },
    {
      "id": "n32",
      "type": "paragraph",
      "order": 31,
      "text": "Three parts, usually with two test takers and no preparation time."
    },
    {
      "id": "n33",
      "type": "heading",
      "order": 32,
      "level": 3,
      "text": "Best for"
    },
    {
      "id": "n34",
      "type": "heading",
      "order": 33,
      "level": 4,
      "text": "Routine everyday German"
    },
    {
      "id": "n35",
      "type": "paragraph",
      "order": 34,
      "text": "Useful for familiar topics, common expressions, short texts, and simple spoken interaction."
    },
    {
      "id": "n36",
      "type": "heading",
      "order": 35,
      "level": 4,
      "text": "Bridge to B1"
    },
    {
      "id": "n37",
      "type": "paragraph",
      "order": 36,
      "text": "A2 is a strong checkpoint before B1 if your goal is residence, citizenship, work, or more independent German."
    },
    {
      "id": "n38",
      "type": "heading",
      "order": 37,
      "level": 3,
      "text": "How to use your practice time"
    },
    {
      "id": "n39",
      "type": "list",
      "order": 38,
      "ordered": false,
      "items": [
        {
          "text": "Familiar topics, routine exchanges, and simple direct information exchange."
        },
        {
          "text": "Reading and listening with multiple-choice and matching-style tasks."
        },
        {
          "text": "Roleplay for partner interaction with the examiner and another test taker."
        }
      ]
    },
    {
      "id": "n40",
      "type": "heading",
      "order": 39,
      "level": 2,
      "text": "Frequently Asked Questions"
    },
    {
      "id": "n41",
      "type": "paragraph",
      "order": 40,
      "text": "Everything you need to know about the exam!"
    },
    {
      "id": "n42",
      "type": "paragraph",
      "order": 41,
      "text": "It tests reading, listening, writing, and speaking through everyday topics, receptive tasks, written prompts, and oral interaction."
    },
    {
      "id": "n43",
      "type": "paragraph",
      "order": 42,
      "text": "Usually citizenship-related language proof points to B1, not A2. Treat A2 as preparation toward B1 unless your authority says otherwise."
    },
    {
      "id": "n44",
      "type": "paragraph",
      "order": 43,
      "text": "Practise asking and answering personal questions, describing everyday situations, and interacting naturally with another test taker."
    },
    {
      "id": "n45",
      "type": "paragraph",
      "order": 44,
      "text": "Last reviewed: May 2026. This page is independent exam preparation. For official registration, fees, dates, and accepted certificate rules, check the exam provider and the institution or authority requesting your certificate."
    }
  ],
