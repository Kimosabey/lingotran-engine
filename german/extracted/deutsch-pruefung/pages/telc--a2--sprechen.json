  "nodes": [
    {
      "id": "n1",
      "type": "heading",
      "order": 0,
      "level": 3,
      "text": "About the Section"
    },
    {
      "id": "n2",
      "type": "image",
      "order": 1,
      "src": "https://deutsch-pruefung.de/_next/image?url=%2Fsection-assets%2Fbear-mascot.webp&w=384&q=75",
      "alt": "Study bear mascot"
    },
    {
      "id": "n3",
      "type": "paragraph",
      "order": 2,
      "text": "The official telc Deutsch A2 Sprechen exam lasts about 15 minutes and is usually done as a pair exam. It has three Teile: introducing yourself, holding a short everyday conversation with question cards, and negotiating a simple joint decision."
    },
    {
      "id": "n4",
      "type": "heading",
      "order": 3,
      "level": 4,
      "text": "Teil 1: Sich vorstellen (Introduce Yourself)"
    },
    {
      "id": "n5",
      "type": "paragraph",
      "order": 4,
      "text": "• Introduce yourself using prompts such as name, age, country, home, languages, job, and hobby"
    },
    {
      "id": "n6",
      "type": "paragraph",
      "order": 5,
      "text": "• The examiner then asks two short follow-up questions"
    },
    {
      "id": "n7",
      "type": "heading",
      "order": 6,
      "level": 4,
      "text": "Teil 2: Ein Alltagsgespräch führen (Everyday Conversation)"
    },
    {
      "id": "n8",
      "type": "paragraph",
      "order": 7,
      "text": "• The examiner gives a topic and six cards; each participant draws three cards"
    },
    {
      "id": "n9",
      "type": "paragraph",
      "order": 8,
      "text": "• Ask three questions and answer three questions on the given everyday topic"
    },
    {
      "id": "n10",
      "type": "heading",
      "order": 9,
      "level": 4,
      "text": "Teil 3: Etwas aushandeln / gemeinsam planen (Negotiate and Plan Together)"
    },
    {
      "id": "n11",
      "type": "paragraph",
      "order": 10,
      "text": "• Work with different suggestion sheets or a mind map"
    },
    {
      "id": "n12",
      "type": "paragraph",
      "order": 11,
      "text": "• Compare ideas, react to your partner, and agree on suitable activities together"
    },
    {
      "id": "n13",
      "type": "heading",
      "order": 12,
      "level": 3,
      "text": "Teil 1 - Sich vorstellen (Introduce Yourself)"
