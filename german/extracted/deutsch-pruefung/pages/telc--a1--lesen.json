      "id": "n3",
      "type": "paragraph",
      "order": 2,
      "text": "This section assesses your comprehension of short, everyday texts like notes, emails, and advertisements. This section consists of three parts."
    },
    {
      "id": "n4",
      "type": "heading",
      "order": 3,
      "level": 4,
      "text": "Teil 1: Informal Text Comprehension"
    },
    {
      "id": "n5",
      "type": "paragraph",
      "order": 4,
      "text": "• Read several short, informal texts (emails or letters)"
    },
    {
      "id": "n6",
      "type": "paragraph",
      "order": 5,
      "text": "• Decide if given statements are true or false ✅ ❌"
    },
    {
      "id": "n7",
