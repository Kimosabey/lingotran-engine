      "type": "paragraph",
      "order": 7,
      "text": "• Read different Advertisements/ Website descriptions 📝"
    },
    {
      "id": "n9",
      "type": "paragraph",
      "order": 8,
      "text": "• Choose the correct advertisement or text from options 'A' or 'B'"
    },
    {
      "id": "n10",
      "type": "heading",
      "order": 9,
      "level": 4,
      "text": "Teil 3: Signs & Notices Comprehension"
