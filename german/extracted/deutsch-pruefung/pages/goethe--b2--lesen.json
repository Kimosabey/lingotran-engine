    {
      "id": "n3",
      "type": "paragraph",
      "order": 2,
      "text": "The Goethe B2 Lesen (Reading) module takes 65 minutes. You read multiple texts and answer questions. You can start with any task. Each task has only one correct answer. Only answers on the answer sheet are graded. No aids (dictionaries, phones, mobile devices) are allowed."
    },
    {
      "id": "n4",
      "type": "heading",
      "order": 3,
      "level": 4,
      "text": "Teil 1: Einstellungen/Haltungen verstehen (Understanding Attitudes)"
    },
    {
      "id": "n5",
      "type": "paragraph",
      "order": 4,
      "text": "• Match texts to statements about attitudes or opinions"
    },
    {
      "id": "n6",
      "type": "paragraph",
      "order": 5,
      "text": "• Task type: Zuordnung (Matching) - 4 texts"
    },
    {
      "id": "n7",
      "type": "heading",
      "order": 6,
      "level": 4,
      "text": "Teil 2: Informationen verstehen (Understanding Information)"
    },
    {
      "id": "n8",
      "type": "paragraph",
      "order": 7,
      "text": "• Read texts and understand detailed information"
    },
    {
      "id": "n9",
      "type": "paragraph",
      "order": 8,
      "text": "• Task type: Zuordnung (Matching) - 6 texts"
    },
    {
      "id": "n10",
      "type": "heading",
      "order": 9,
      "level": 4,
      "text": "Teil 3: Informationen verstehen (Understanding Information)"
    },
    {
      "id": "n11",
      "type": "paragraph",
      "order": 10,
      "text": "• Read texts and answer comprehension questions"
    },
    {
      "id": "n12",
      "type": "paragraph",
      "order": 11,
      "text": "• Task type: Wahl (3-gliedrig MC) - Multiple Choice with 3 options"
    },
    {
      "id": "n13",
      "type": "heading",
      "order": 12,
      "level": 4,
      "text": "Teil 4: Standpunkte verstehen (Understanding Viewpoints)"
    },
    {
      "id": "n14",
      "type": "paragraph",
      "order": 13,
      "text": "• Read texts and identify different viewpoints"
    },
    {
      "id": "n15",
      "type": "paragraph",
      "order": 14,
      "text": "• Task type: Zuordnung (Matching) - 8 texts"
    },
    {
      "id": "n16",
      "type": "heading",
      "order": 15,
      "level": 4,
      "text": "Teil 5: Regeln/Instruktionen verstehen (Understanding Rules/Instructions)"
    },
    {
      "id": "n17",
      "type": "paragraph",
      "order": 16,
      "text": "• Read formal texts with rules or instructions"
    },
    {
      "id": "n18",
      "type": "paragraph",
