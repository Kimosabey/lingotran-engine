    {
      "id": "n17",
      "type": "heading",
      "order": 16,
      "level": 3,
      "text": "TELC C1 Exam Structure"
    },
    {
      "id": "n18",
      "type": "heading",
      "order": 17,
      "level": 4,
      "text": "Receptive Skills"
    },
    {
      "id": "n19",
      "type": "heading",
      "order": 18,
      "level": 4,
      "text": "Productive Skills"
    },
    {
      "id": "n20",
      "type": "paragraph",
      "order": 19,
      "text": "Official exam context"
    },
    {
      "id": "n21",
      "type": "heading",
      "order": 20,
      "level": 2,
      "text": "What the TELC C1 Exam Checks"
    },
    {
      "id": "n22",
      "type": "paragraph",
      "order": 21,
      "text": "telc Deutsch C1 confirms advanced German skills for learners who can understand demanding texts, express themselves fluently, and use German flexibly in study, work, and public life."
    },
    {
      "id": "n23",
      "type": "heading",
      "order": 22,
      "level": 3,
      "text": "Exam format and timing"
    },
    {
      "id": "n24",
      "type": "paragraph",
      "order": 23,
      "text": "The official telc Deutsch C1 exam has a written examination and an oral examination. The written part includes 90 minutes for reading and language elements, 40 minutes for listening, and 70 minutes for written expression. The oral exam lasts about 16 minutes after preparation."
    },
    {
      "id": "n25",
      "type": "heading",
      "order": 24,
      "level": 4,
      "text": "Reading and language elements"
    },
    {
      "id": "n26",
      "type": "paragraph",
      "order": 25,
      "text": "90 minutes"
    },
    {
      "id": "n27",
      "type": "paragraph",
      "order": 26,
      "text": "Three reading tasks plus Sprachbausteine with sentence reconstruction, section matching, statement evaluation, title choice, and 22 language gaps."
    },
    {
      "id": "n28",
      "type": "heading",
      "order": 27,
      "level": 4,
      "text": "Listening"
    },
    {
      "id": "n29",
      "type": "paragraph",
      "order": 28,
      "text": "40 minutes"
    },
    {
      "id": "n30",
      "type": "paragraph",
      "order": 29,
      "text": "Opinion matching and radio interview tasks with once-played audio, paraphrase traps, and inference-heavy details."
    },
    {
      "id": "n31",
      "type": "heading",
      "order": 30,
      "level": 4,
      "text": "Writing"
    },
    {
      "id": "n32",
      "type": "paragraph",
      "order": 31,
      "text": "70 minutes"
    },
    {
      "id": "n33",
      "type": "paragraph",
      "order": 32,
      "text": "One argumentative text of about 350 words based on one of two topics and opposing quotations."
    },
    {
      "id": "n34",
      "type": "heading",
      "order": 33,
      "level": 4,
      "text": "Speaking"
    },
    {
      "id": "n35",
      "type": "paragraph",
      "order": 34,
      "text": "Approx. 16 minutes"
    },
    {
      "id": "n36",
      "type": "paragraph",
      "order": 35,
      "text": "Advanced oral expression with preparation time, structured presentation, argumentation, and nuanced interaction."
    },
    {
      "id": "n37",
      "type": "heading",
      "order": 36,
      "level": 3,
      "text": "Best for"
    },
    {
      "id": "n38",
      "type": "heading",
      "order": 37,
      "level": 4,
      "text": "University and advanced study goals"
    },
    {
      "id": "n39",
      "type": "paragraph",
      "order": 38,
      "text": "Useful when your route requires C1-level German or when you need strong academic reading, listening, and writing skills."
    },
    {
      "id": "n40",
      "type": "heading",
      "order": 39,
      "level": 4,
      "text": "Professional communication"
    },
    {
      "id": "n41",
      "type": "paragraph",
      "order": 40,
      "text": "Suitable for learners who need to argue precisely, understand detailed public discourse, and write structured position texts."
    },
    {
      "id": "n42",
      "type": "heading",
      "order": 41,
      "level": 3,
      "text": "How to use your practice time"
    },
    {
      "id": "n43",
      "type": "list",
      "order": 42,
      "ordered": false,
      "items": [
        {
          "text": "Discourse-level reading: references, paragraph function, rhetorical stance, and title logic."
        },
        {
          "text": "Sprachbausteine with C1 grammar, verb government, collocations, word formation, and text logic."
        },
        {
          "text": "Listening that tests corrections, concessions, inferred meaning, and radio-interview detail."
        },
        {
          "text": "Argumentative writing around 350 words with a clear line of argument and controlled C1 syntax."
        }
      ]
    },
    {
      "id": "n44",
      "type": "heading",
      "order": 43,
      "level": 2,
      "text": "Frequently Asked Questions"
    },
    {
      "id": "n45",
      "type": "paragraph",
      "order": 44,
      "text": "Everything you need to know about the exam!"
    },
    {
      "id": "n46",
      "type": "paragraph",
      "order": 45,
      "text": "TELC lists a written examination with 90 minutes for reading/language elements, 40 minutes for listening, and 70 minutes for writing, plus an oral examination of about 16 minutes after preparation."
    },
    {
      "id": "n47",
      "type": "paragraph",
      "order": 46,
      "text": "C1 tasks rely less on direct keyword recognition and more on text logic, implicit meaning, register, dense grammar, paraphrase, and precise argumentation."
    },
    {
      "id": "n48",
      "type": "paragraph",
      "order": 47,
      "text": "This page prepares TELC C1-style skills and tasks. If a university asks for a specific certificate such as telc Deutsch C1 Hochschule, always confirm the exact accepted exam before booking."
    },
    {
      "id": "n49",
      "type": "paragraph",
      "order": 48,
      "text": "Last reviewed: May 2026. This page is independent exam preparation. For official registration, fees, dates, and accepted certificate rules, check the exam provider and the institution or authority requesting your certificate."
    }
  ],
