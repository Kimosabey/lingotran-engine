      "id": "n3",
      "type": "paragraph",
      "order": 2,
      "text": "The TELC B1 Hörverstehen (Listening) module takes 30 minutes and consists of three parts. You will hear various workplace and everyday texts."
    },
    {
      "id": "n4",
      "type": "heading",
      "order": 3,
      "level": 4,
      "text": "Teil 1: Globalverstehen (Global Understanding)"
    },
    {
      "id": "n5",
      "type": "paragraph",
      "order": 4,
      "text": "• Listen to workplace conversations and situations"
    },
    {
      "id": "n6",
      "type": "paragraph",
      "order": 5,
      "text": "• Understand the main ideas and context"
    },
    {
      "id": "n7",
      "type": "heading",
      "order": 6,
      "level": 4,
      "text": "Teil 2: Detailverstehen (Detailed Understanding)"
    },
    {
      "id": "n8",
      "type": "paragraph",
      "order": 7,
      "text": "• Listen to longer workplace dialogues or announcements"
    },
    {
      "id": "n9",
      "type": "paragraph",
      "order": 8,
      "text": "• Identify specific details and information"
    },
    {
      "id": "n10",
      "type": "heading",
      "order": 9,
      "level": 4,
      "text": "Teil 3: Selektives Verstehen (Selective Understanding)"
    },
    {
      "id": "n11",
      "type": "paragraph",
      "order": 10,
      "text": "• Listen to professional conversations or presentations"
    },
    {
      "id": "n12",
      "type": "paragraph",
      "order": 11,
      "text": "• Extract specific information selectively"
