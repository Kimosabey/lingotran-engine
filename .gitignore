# Python build artifacts (never source, always regenerable)
__pycache__/
*.pyc

# Editor directories and files
.idea
.vscode
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Dependencies
node_modules
bower_components
jspm_packages
vendor

# API tools and other IDEs
.claude/
.gemini/

# Temp files
*.tmp
*.bak
*.log

# Large source binaries & scan artifacts — kept on disk, not tracked in git.
# (Source PDFs, 300-DPI page renders, and zoom-crop scratch images.)
french/*.pdf
french/pdf/**/*.pdf
french/extracted/*/images/
french/extracted/_tools/*.png
*.png
!site/assets/img/*.png

# German raw source materials (officially-published PDFs/audio) — structure
# and READMEs are tracked, the binaries themselves are not.
german/pdf/**/*.pdf
german/audio/**/*.mp4

# German media pipeline — rasterized page renders + zoom-crop scratch (like
# french/extracted/*/images/). Transcribed .md/.json ARE tracked.
german/extracted/*/images/
german/extracted/_tools/_z_*.png
